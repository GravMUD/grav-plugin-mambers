{% extends 'mambers/theme-page.html.twig' %}



{% block mambers_content %}

<article class="mambers-post-page">

  <p><a class="mambers-link" href="{{ profile_url|e('html_attr') }}">← {{ post.author_name|default(post.author)|e }}</a></p>



  <div class="mambers-activity mambers-activity--single"
    data-mambers-activity
    data-mode="single"
    data-api="{{ activity_api|e('html_attr') }}"
    data-user="{{ post.author|e('html_attr') }}"
    data-can-edit="{{ post_can_edit|default(false) ? '1' : '0' }}"
    data-giphy="{{ activity_giphy_enabled|default(false) ? '1' : '0' }}"
    data-reactions="{{ activity_reactions_enabled|default(true) ? '1' : '0' }}"
    {% include 'mambers/partials/activity-media-limits.html.twig' %}
    {% if profile_write_nonce is defined %}data-nonce="{{ profile_write_nonce|e('html_attr') }}"{% elseif graph_nonce is defined %}data-nonce="{{ graph_nonce|e('html_attr') }}"{% endif %}
    data-post="{{ post|json_encode|e('html_attr') }}">

  </div>

</article>

{% endblock %}

