{% extends 'mambers/theme-page.html.twig' %}



{% block mambers_content %}

<article class="mambers-feed-page">

  <header class="mambers-feed-head">

    <h1>Village feed</h1>

    <p class="mambers-muted">Recent posts from members — Mambers activity, not Forumz.</p>

  </header>

  {% include 'mambers/partials/members-nav.html.twig' with { members_nav_active: 'feed' } %}



  <div class="mambers-activity"
    data-mambers-activity
    data-mode="site"
    data-api="{{ activity_api|e('html_attr') }}"
    data-feed="1"
    data-feed-tabs="1"
    data-giphy="{{ activity_giphy_enabled|default(false) ? '1' : '0' }}"
    data-reactions="{{ activity_reactions_enabled|default(true) ? '1' : '0' }}"
    {% include 'mambers/partials/activity-media-limits.html.twig' %}
    {% if feed_nonce is defined %}data-nonce="{{ feed_nonce|e('html_attr') }}"{% endif %}>

    <p class="mambers-activity-loading">Loading feed…</p>

  </div>

</article>

{% endblock %}

